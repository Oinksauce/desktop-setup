# Discord Vault Bot — Environment Configuration
# Copy this file to ~/.claude/scripts/.discord-vault-bot.env and fill in values.
# Never commit the real .env file — it contains secrets.

# Required: Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Required: Channel ID the bot listens on (right-click channel → Copy Channel ID)
DISCORD_CHANNEL_ID=your-channel-id-here

# Vault path on this machine — set to wherever Obsidian Sync places the vault
# Typically ~/Documents/JonVaultSyn (check in Obsidian after first sync)
VAULT_PATH=/home/jon/Documents/JonVaultSyn

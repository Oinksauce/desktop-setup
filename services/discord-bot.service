[Unit]
Description=Discord Vault Bot (Claude Code Channels)
After=network-online.target
ConditionPathIsDirectory=__USER_HOME__/Documents/JonVaultSyn/.obsidian

[Service]
Type=simple
User=__USER__
Environment=PATH=__USER_HOME__/.local/bin:__USER_HOME__/.bun/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=__USER_HOME__/.local/bin/claude --channels plugin:discord@claude-plugins-official
WorkingDirectory=__USER_HOME__/Documents/JonVaultSyn
EnvironmentFile=__USER_HOME__/.claude/channels/discord/.env
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

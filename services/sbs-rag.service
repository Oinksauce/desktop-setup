[Unit]
Description=SBS RAG Semantic Search Service
Documentation=https://github.com/Oinksauce/claude-config
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=__USER__
WorkingDirectory=__USER_HOME__/sbs-rag
ExecStart=__USER_HOME__/sbs-rag/venv/bin/python3 __USER_HOME__/sbs-rag/rag_service.py --ollama-url http://localhost:11434
Restart=on-failure
RestartSec=10
StandardOutput=append:__USER_HOME__/sbs-rag/rag_service.log
StandardError=append:__USER_HOME__/sbs-rag/rag_service.log
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
